# ===== Banco de dados (Supabase ou Neon — Postgres) =====
# No Supabase: Project Settings > Database > Connection string (modo "URI").
# Use a porta 6543 (pooler) para a app e 5432 (direta) para migrations, se aplicável.
DATABASE_URL="postgresql://usuario:senha@host:5432/postgres?sslmode=require"

# ===== Segurança do painel admin =====
# Segredo para assinar a sessão (JWT). Gere um valor longo e aleatório:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
AUTH_SECRET="troque-por-um-valor-longo-e-aleatorio"

# Conta admin inicial (usada pelo script scripts/criar-admin.mjs)
ADMIN_EMAIL="contato@vapocamping.com.br"
ADMIN_SENHA="defina-uma-senha-forte"

# ===== Contato / WhatsApp =====
# Número no formato internacional, só dígitos (Brasil: 55 + DDD + número)
NEXT_PUBLIC_WHATSAPP="5511986659885"
